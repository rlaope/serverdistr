{
  "__inputs": [
    {"name": "DS_LOKI", "type": "datasource", "pluginId": "loki"}
  ],
  "title": "KHOPE - Service Logs",
  "tags": ["khope"],
  "timezone": "browser",
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "All Services Logs",
      "type": "logs",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 0},
      "targets": [{"expr": "{job=\"spring-services\"}", "refId": "A"}],
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "options": {"showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "sortOrder": "Descending"}
    },
    {
      "id": 2,
      "title": "ERROR Logs Only",
      "type": "logs",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 12},
      "targets": [{"expr": "{job=\"spring-services\"} |= \"ERROR\"", "refId": "A"}],
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "options": {"showTime": true, "showLabels": true, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending"}
    },
    {
      "id": 3,
      "title": "Auth Service Logs",
      "type": "logs",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 22},
      "targets": [{"expr": "{job=\"spring-services\", service=\"auth-service\"}", "refId": "A"}],
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "options": {"showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending"}
    },
    {
      "id": 4,
      "title": "Product Service Logs",
      "type": "logs",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 22},
      "targets": [{"expr": "{job=\"spring-services\", service=\"product-service\"}", "refId": "A"}],
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "options": {"showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending"}
    },
    {
      "id": 5,
      "title": "Order Service Logs",
      "type": "logs",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 30},
      "targets": [{"expr": "{job=\"spring-services\", service=\"order-service\"}", "refId": "A"}],
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "options": {"showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending"}
    },
    {
      "id": 6,
      "title": "Gateway Service Logs",
      "type": "logs",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 30},
      "targets": [{"expr": "{job=\"spring-services\", service=\"gateway-service\"}", "refId": "A"}],
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "options": {"showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending"}
    },
    {
      "id": 7,
      "title": "Log Volume by Level",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 38},
      "targets": [{"expr": "sum(count_over_time({job=\"spring-services\"}[1m])) by (level)", "legendFormat": "{{level}}", "refId": "A"}],
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"}
    }
  ]
}
